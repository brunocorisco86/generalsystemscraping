# --- Renomeie este arquivo para .env e preencha as variáveis abaixo ---
# NÃO comite o arquivo .env para o repositório Git.

# --- [00] Identificação do Proprietário (Admin) ---
OWNER_NAME="Nome Completo do Proprietário"
OWNER_CPF="000.000.000-00"
TELEGRAM_CHAT_ID="SEU_CHAT_ID_NUMERICO"  # Obtenha com @userinfobot
TELEGRAM_USERNAME="seu_usuario_telegram"

# --- [01] Identificação da Propriedade ---
PROP_NAME="Nome da Propriedade (Ex: Fazenda São João)"
PROP_ADDRESS="Endereço Completo, Cidade - UF"
PROP_CADPRO="000.000.000-0"

# --- [02] Estruturas de Produção (Tanques/Aviários) ---
# Você pode cadastrar múltiplas estruturas separando por vírgula
# Ex: STRUCT_NAME="Tanque 01, Tanque 02, Tanque 03"
STRUCT_NAME="Tanque 01"
STRUCT_PLUSCODE="87G8XXXX+XX" # Localização Plus Code da estrutura
STRUCT_TYPE_ID=1 # Ver docs/catalogos.md (1=Piscicultura, 2=Avicultura, etc)

# --- [03] Tokens de Bots do Telegram ---
# Token principal para notificações de scripts (relatórios, migração)
TELEGRAM_TOKEN="SEU_TOKEN_AQUI"

# Token para o bot de Biometria (Gerenciamento de Lotes)
BOT_BIOMETRIA_TOKEN="TOKEN_DO_BOT_DE_BIOMETRIA"

# Token para o bot de Qualidade da Água
BOT_AGUA_TOKEN="TOKEN_DO_BOT_DE_QUALIDADE_DA_AGUA"

# --- [04] Banco de Dados ---
# Caminho para o banco de dados SQLite local
SQLITE_DB_PATH="data/piscicultura_dados.db"

# Configurações de conexão para o PostgreSQL (Docker)
PG_HOST="localhost"
PG_DBNAME="piscicultura_history"
PG_USER="admin"
PG_PASSWORD="sua_senha_segura"
PG_PORT="5432"

# --- [05] Infraestrutura Local ---
# Caminho ABSOLUTO para o diretório do projeto (ex: /home/bruno/projeto)
# Use 'pwd' no terminal para obter este valor
PROJECT_ROOT="/caminho/absoluto/para/este/projeto"
REPORTS_DIR="reports"
LOGS_DIR="logs"

# --- [06] Scraping (Selenium - Noctua-IoT) ---
URL_LOGIN="https://general-system.noctua-iot.com/login"
LOGIN_EMAIL="seu_email@exemplo.com"
LOGIN_PASSWORD="sua_senha_aqui"
CHROMEDRIVER_PATH="/usr/bin/chromedriver"

# --- [07] Alertas e Monitoramento ---
LIMITE_OXIGENIO_CRITICO=1.5
MINUTOS_OFFLINE_ALERTA=30

# --- [08] Backup (Cloudflare R2) ---
# Obtenha estas chaves no painel da Cloudflare > R2 > Manage R2 API Tokens
R2_ACCESS_KEY_ID="SUA_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="SUA_SECRET_ACCESS_KEY"
R2_ENDPOINT_URL="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET_NAME="piscicultura-backups"
