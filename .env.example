# Renomeie este arquivo para .env e preencha as variáveis abaixo.
# NÃO comite o arquivo .env para o repositório Git.

# -- Telegram --
# Token principal para notificações de scripts (relatórios, migração)
TELEGRAM_TOKEN="SEU_TOKEN_AQUI"
TELEGRAM_CHAT_ID="SEU_CHAT_ID_AQUI"

# Token para o bot de Biometria
BOT_BIOMETRIA_TOKEN="TOKEN_DO_BOT_DE_BIOMETRIA"

# Token para o bot de Qualidade da Água
BOT_AGUA_TOKEN="TOKEN_DO_BOT_DE_QUALIDADE_DA_AGUA"

# -- Banco de Dados --
# Caminho para o banco de dados SQLite local
SQLITE_DB_PATH="data/piscicultura_dados.db"

# Configurações de conexão para o banco de dados PostgreSQL de histórico
PG_HOST="localhost"
PG_DBNAME="piscicultura_history"
PG_USER="seu_usuario"
PG_PASSWORD="sua_senha"
PG_PORT="5432"

# -- Diretórios --
# Caminho para a pasta onde os relatórios (imagens) são salvos
REPORTS_DIR="reports"
PROJECT_ROOT="/media/brunoconter/DOCUMENTOS/9_ALPINE_GENERAL"
